{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "mysrvr.org",
  "description": "Documentation for mysrvr.org — the Discord server listing platform.",
  "colors": {
    "primary": "#5865F2",
    "light": "#7983F5",
    "dark": "#4752C4"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "https://mysrvr.org"
        },
        {
          "anchor": "Dashboard",
          "icon": "layout-dashboard",
          "href": "https://mysrvr.org/dashboard"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get Started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "introduction",
          "getting-started"
        ]
      },
      {
        "group": "Using mysrvr.org",
        "icon": "book-open",
        "expanded": true,
        "pages": [
          "bot-commands",
          "dashboard",
          "subdomain-system"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://mysrvr.org"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Login with Discord",
      "href": "https://mysrvr.org/auth/login"
    }
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/yourinvite"
    }
  }
}
